rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBookingOwner() {
      return request.auth != null
        && resource.data.customerId == request.auth.uid;
    }

    match /admins/{uid} {
      allow read, write: if false;
    }

    match /bookings/{id} {
      allow read: if isAdmin() || isBookingOwner();
      allow create: if false;
      allow delete: if false;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'deletedAt', 'deletedBy', 'memberLastStatus', 'invisible']);
    }

    match /siteSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** FCM 裝置 token：僅 Cloud Functions（Admin SDK）讀寫，客戶端不透過 Rules 存取 */
    match /pushDeviceTokens/{id} {
      allow read, write: if false;
    }
  }
}
