rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBookingOwner() {
      return request.auth != null
        && resource.data.customerId == request.auth.uid;
    }

    /** 後台封存（invisible=true）：須為已取消、已完成，或有 completedAt（與前台「已完成」判斷一致） */
    function bookingTerminalForArchive() {
      let st = request.resource.data.get('status', '');
      return (st is string && (st.lower() == 'done' || st.lower() == 'cancelled'))
        || request.resource.data.get('completedAt', null) != null;
    }

    match /admins/{uid} {
      allow read, write: if false;
    }

    match /bookings/{id} {
      allow read: if isAdmin() || isBookingOwner();
      allow create: if false;
      allow delete: if false;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'deletedAt', 'deletedBy', 'memberLastStatus', 'invisible'])
        && (request.resource.data.get('invisible', false) != true
          || resource.data.get('invisible', false) == true
          || bookingTerminalForArchive());
    }

    match /siteSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** 訪次累計：僅 Cloud Functions（Admin SDK）寫入；任何人可讀（可選用於即時看板） */
    match /siteStats/{id} {
      allow read: if true;
      allow write: if false;
    }

    /** 會員餘額／次數／點數：僅 Cloud Functions（Admin SDK）讀寫 */
    match /customers/{uid} {
      allow read, write: if false;
    }

    /** 儲值與扣款紀錄：僅後台／Functions */
    match /walletTransactions/{id} {
      allow read, write: if false;
    }

    /** 輪盤獎項與紀錄：僅管理後台與 Functions */
    match /wheelPrizes/{id} {
      allow read, write: if false;
    }

    match /wheelSpins/{id} {
      allow read, write: if false;
    }

    /**
     * 客服對話：文件 id = Auth UID（含匿名）。客戶端僅讀取；建立、回覆、重新開啟與結案皆走
     * Cloud Functions（Admin SDK），避免客戶端直接改寫對話狀態或摘要欄位。
     */
    match /supportThreads/{customerId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
      allow create, update, delete: if false;

      match /messages/{msgId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
        allow create, update, delete: if false;
      }
    }
  }
}
