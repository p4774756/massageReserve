rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBookingOwner() {
      return request.auth != null
        && resource.data.customerId == request.auth.uid;
    }

    match /admins/{uid} {
      allow read, write: if false;
    }

    match /bookings/{id} {
      allow read: if isAdmin() || isBookingOwner();
      allow create: if false;
      allow delete: if false;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'deletedAt', 'deletedBy', 'memberLastStatus', 'invisible']);
    }

    match /siteSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** 訪次累計：僅 Cloud Functions（Admin SDK）寫入；任何人可讀（可選用於即時看板） */
    match /siteStats/{id} {
      allow read: if true;
      allow write: if false;
    }

    /** FCM 裝置 token：僅 Cloud Functions（Admin SDK）讀寫，客戶端不透過 Rules 存取 */
    match /pushDeviceTokens/{id} {
      allow read, write: if false;
    }

    /**
     * 客服對話：文件 id = Auth UID（含匿名）。僅本人與管理員可讀；寫入以「路徑 uid == auth.uid」為主，
     * 規則刻意保持簡單，避免 keys()/status/get 組合在評估時誤擋（含訪客匿名）。
     */
    match /supportThreads/{customerId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);

      /* 僅鎖「路徑 id == 登入 uid」；其餘欄位由 App 負責，避免規則與實際寫入欄位細微差異導致拒絕 */
      allow create: if request.auth != null && request.auth.uid == customerId;

      allow update: if isAdmin()
        && request.resource.data.customerId == resource.data.customerId;

      /* 會員更新：只鎖路徑 uid；不要求 customerId 欄位與 resource 逐字相等（部分 update 合併下易誤擋「重新開啟」） */
      allow update: if request.auth != null && request.auth.uid == customerId;

      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);

        function supportThreadDoc() {
          return get(/databases/$(database)/documents/supportThreads/$(customerId));
        }

        allow create: if request.auth != null
          && supportThreadDoc().exists
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && (
            (isAdmin() && request.resource.data.sender == "admin")
            || (request.auth.uid == customerId && request.resource.data.sender == "customer")
          );

        allow update, delete: if false;
      }
    }

    /**
     * 預約頁底部「心得與評價」：所有人可讀；已登入（含匿名）可新增自己的一筆。
     * 不開放修改／刪除（管理員可於 Console 手動處理）。
     */
    match /guestbookPosts/{id} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 48
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 800
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.keys().hasOnly(["authorUid", "displayName", "text", "rating", "createdAt"]);

      allow update, delete: if false;
    }
  }
}
