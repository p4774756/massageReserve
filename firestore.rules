rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isBookingOwner() {
      return request.auth != null
        && resource.data.customerId == request.auth.uid;
    }

    match /admins/{uid} {
      allow read, write: if false;
    }

    match /bookings/{id} {
      allow read: if isAdmin() || isBookingOwner();
      allow create: if false;
      allow delete: if false;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'deletedAt', 'deletedBy', 'memberLastStatus', 'invisible']);
    }

    match /siteSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /** 訪次累計：僅 Cloud Functions（Admin SDK）寫入；任何人可讀（可選用於即時看板） */
    match /siteStats/{id} {
      allow read: if true;
      allow write: if false;
    }

    /**
     * 客服對話：文件 id = Auth UID（含匿名）。客戶端僅讀取；建立、回覆、重新開啟與結案皆走
     * Cloud Functions（Admin SDK），避免客戶端直接改寫對話狀態或摘要欄位。
     */
    match /supportThreads/{customerId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
      allow create, update, delete: if false;

      match /messages/{msgId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == customerId);
        allow create, update, delete: if false;
      }
    }

    /**
     * 預約頁底部「心得與評價」：所有人可讀；已登入（含匿名）可新增自己的一筆。
     * 不開放修改／刪除（管理員可於 Console 手動處理）。
     */
    match /guestbookPosts/{id} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 48
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 800
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(["authorUid", "displayName", "text", "rating", "createdAt"]);

      allow update, delete: if false;
    }
  }
}
