# 從 Firebase Console → 專案設定 → 一般 → 你的應用程式 → SDK 設定
# 輪盤 seed 腳本（scripts/seed-wheel-prizes.mjs）用：須為 admins 集合內的管理員
# SEED_WHEEL_ADMIN_EMAIL=
# SEED_WHEEL_ADMIN_PASSWORD=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# 選填：網頁 FCM 訂閱用（Console → Cloud Messaging → Web 推播憑證）
# VITE_FIREBASE_VAPID_KEY=
